# Keep the actual .env and Gmail refresh token out of Git.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_TOKEN_PATH=.secrets/gmail-token.json
GMAIL_QUERY=is:unread has:attachment filename:pdf
DATABASE_URL=postgresql://postgres.yalmpcjdegakctcyaqpw:replace-me@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres
LOGFIRE_SEND=false

# --- PDF parser (stage 2) ---
PARSER_BASE_URL=http://localhost:8010
PARSER_USER=tender-eval
PARSER_API_KEY=
PARSE_POLL_INTERVAL_SECONDS=5
PARSE_MAX_POLL_ATTEMPTS=120
PARSE_WORKER_ENABLED=true
PARSE_WORKER_INTERVAL_SECONDS=30
PARSE_BATCH_SIZE=5
PARSE_MAX_ATTEMPTS=3

# --- Tender/bid evaluation (stage 3) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1
REVIEWER_EMAIL=navchetna.intel@gmail.com
EVAL_BATCH_SIZE=5

